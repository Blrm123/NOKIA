# GitHub Repository Workflow Backend — Environment Variables
# ---------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Optional: HMAC secret used to verify GitHub webhook signatures.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable signature verification (development only).
GITHUB_SECRET=

# Directory where cloned repositories will be stored.
REPOSITORY_ROOT=repositories

# Directory where workflow JSON state files will be stored.
WORKFLOW_PATH=workflow

# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Path to the application log file (relative to the project root).
LOG_FILE=logs/backend.log


# -----------------------------------------------------------------------
# HOW TO RUN
# -----------------------------------------------------------------------

# Start the backend server:
#   uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

# Generate a webhook secret:
#   python -c "import secrets; print(secrets.token_hex(32))"

# Expose localhost via ngrok:
#   ngrok config add-authtoken <YOUR_NGROK_AUTH_TOKEN>
#   ngrok http 8000

# Configure GitHub Webhook:
#   1. Go to your GitHub repository
#   2. Click Settings → Webhooks → Add webhook
#   3. Payload URL : https://<your-ngrok-url>.ngrok-free.app/webhook/github
#   4. Content type: application/json
#   5. Secret      : <value of GITHUB_SECRET above>
#   6. SSL         : Enable
#   7. Events      : Just the push event
#   8. Click Save
